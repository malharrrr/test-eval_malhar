    "hono": "^4.8.2",
    "zod": "catalog:",
    "@healos/shared": "workspace:*",
    "@healos/llm": "workspace:*"
  },
  "devDependencies": {
    "@test-evals/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
