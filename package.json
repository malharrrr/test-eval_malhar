{
  "name": "test-evals",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "better-auth": "1.5.5",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "eval": "bun --filter @test-evals/server run eval",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @test-evals/db db:push",
    "db:studio": "turbo -F @test-evals/db db:studio",
    "db:generate": "turbo -F @test-evals/db db:generate",
    "db:migrate": "turbo -F @test-evals/db db:migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@test-evals/env": "workspace:*",
    "dotenv": "catalog:",
    "llm": "^1.0.7",
    "p-limit": "^7.3.0",
    "shared": "^0.2.0",
    "string-similarity": "^4.0.4",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@test-evals/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/string-similarity": "^4.0.2",
    "server": "workspace:*",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.5"
}
